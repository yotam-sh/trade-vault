# TradeVault Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Flask secret key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# Set to 'true' only for local development. Never 'true' in production.
DEBUG=false

# Port the app listens on (default: 2501)
PORT=2501

# Absolute path to db.json (set automatically by docker-compose.yml)
# Bare-metal installs don't need this — it's auto-detected.
# DB_PATH=/data/db/db.json
